{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv ./src/types.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply collect-db",
    "db:migrate:local": "wrangler d1 migrations apply collect-db --local",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.3",
    "better-auth": "^1.5.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.7.7",
    "rss-parser": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250321.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.4",
    "wrangler": "^4.71.0"
  }
}
