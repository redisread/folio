api/.wrangler/
api/dist/
frontend/.astro/
frontend/dist/
frontend/.cloudflare/
mobile/.dart_tool/
mobile/build/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies

# pnpm
.pnpm-store/
node_modules/

